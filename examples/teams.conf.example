# ============================================================
# teams.conf.example
# Copy this file to teams.conf and edit to match your setup.
# Then source it in sonar-weekly-report.sh or pass as env var.
# ============================================================

# SonarQube server URL (no trailing slash)
SONAR_HOST_URL="https://sonarqube.yourcompany.com"

# Admin token — generate in: SonarQube > My Account > Security > Tokens
# Required permissions: Browse (all projects) or Global Admin
SONAR_ADMIN_TOKEN="sqp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Team → Project Key Mapping ────────────────────────────────
# Format: "TEAM_NAME|PROJECT_KEY1,PROJECT_KEY2,PROJECT_KEY3"
# TEAM_NAME  : used in the output filename and report header
# PROJECT_KEY: must match the key in SonarQube exactly (case-sensitive)
#
# Example:
TEAMS="
frontend|frontend-web,frontend-mobile,design-system
backend|auth-service,payments-api,notification-service
platform|infra-core,ci-platform,k8s-operator
data|etl-pipeline,data-warehouse,analytics-api
"
