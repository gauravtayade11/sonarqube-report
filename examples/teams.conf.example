# ============================================================
# teams.conf.example
# Copy values into scripts/sonar-report.sh to configure.
# ============================================================

# SonarQube server URL (no trailing slash)
SONAR_HOST_URL="https://sonarqube.yourcompany.com"

# Admin token — generate in: SonarQube > My Account > Security > Tokens
# Required permissions: Browse (all projects) or Global Admin
SONAR_ADMIN_TOKEN="sqp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Report name — used as the report heading and output filename
# Output: sonarqube-report-REPORT_NAME-DATE.html
# Use lowercase letters, numbers, and hyphens only
REPORT_NAME="platform"

# All projects are auto-discovered from SonarQube — no project keys needed.
